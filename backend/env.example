#
# Kairo backend environment
#
# IMPORTANT:
# - Do NOT commit real secrets. This file is a template only.
# - Copy to `backend/.env` and fill values.
#

# Server
PORT=3001
HOST=0.0.0.0

# Sui admin signer (controls publish/create/binding transactions).
# Use an ED25519 bech32 secret key that starts with `suiprivkey...`
SUI_NETWORK=testnet
SUI_ADMIN_SECRET_KEY=suiprivkey...

# Sui RPC URL (STRONGLY recommended for production).
# Public testnet RPC endpoints may have strict rate limits that cause 429
# errors during IkaClient initialization and protocol params fetching.
# Use a dedicated high-throughput endpoint for production.
# This URL is also passed to the browser extension for client-side SDK calls.
SUI_RPC_URL=https://your-sui-rpc.example.com

# Optional gas budgets (mist)
SUI_DKG_GAS_BUDGET_MIST=500000000
SUI_SIGN_GAS_BUDGET_MIST=200000000

# Policy gating (optional: extension can pass per-user policyId/policyVersion in requests)
KAIRO_POLICY_ID=
KAIRO_POLICY_VERSION=

# Move package ids (strongly recommended to set after you publish/upgrade)
KAIRO_POLICY_MINT_PACKAGE_ID=0x...
KAIRO_CUSTODY_PACKAGE_ID=0x...

# Custody chain shared object id (required for custody event recording)
KAIRO_CUSTODY_CHAIN_OBJECT_ID=0x...

# Policy Registry shared object id (required for PolicyBinding + receipt minting)
KAIRO_POLICY_REGISTRY_ID=0x...

# Policy Vault shared object id (REQUIRED: all signing goes through the vault)
KAIRO_POLICY_VAULT_OBJECT_ID=0x...

# Bootstrap API key. When set, enables auth. When not set, auth is disabled (open mode).
# Generate with: openssl rand -hex 32
KAIRO_ADMIN_KEY=

# Supabase persistence (optional but recommended for API key durability across deploys)
# If set, API keys + wallet ownership mappings are persisted to this table.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
KAIRO_API_KEYS_TABLE=api_keys

